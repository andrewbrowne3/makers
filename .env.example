# ── LLM (brain) ──────────────────────────────────────────
LLM_PROVIDER=ollama               # ollama | anthropic | openai | google
LLM_MODEL=gemma4:e4b
OLLAMA_BASE_URL=http://localhost:11434
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ── Image generation (pixels) ────────────────────────────
IMAGE_GEN_PROVIDER=nano_banana    # nano_banana | gpt_image_1 | flux_kontext | stub
IMAGE_GEN_MODEL=gemini-2.5-flash-image

# ── Embeddings / router ──────────────────────────────────
EMBED_PROVIDER=ollama             # ollama | openai
EMBED_MODEL=mxbai-embed-large
CHROMA_DIR=./db/chroma_db
ROUTE_SCORE_THRESHOLD=0.3

# ── S3 ───────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
S3_KEY_PREFIX=makersgarments
S3_PRESIGN_EXPIRY=3600

# ── Template / asset directories ─────────────────────────
EXEC_ROOT=/home/ab/Executive Crew Socks
MOCK_DIR=${EXEC_ROOT}/PNG_3D_Mockup_Exec
PSD_DIR=${EXEC_ROOT}/PHOTOSHOP_FILES_FOR_DESIGNERS_Exec
PROD_DIR=${EXEC_ROOT}/ProdFiles_Exec
TRAINING_DIR=${EXEC_ROOT}/TRAINING_DATA

# ── Evaluator ────────────────────────────────────────────
EVALUATOR_ENABLED=true
EVALUATOR_PROVIDER=ollama         # reuses LLM provider if "same"; otherwise ollama/anthropic/openai
EVALUATOR_MODEL=gemma4:e4b
EVALUATOR_THRESHOLD=0.6           # below → retry, escalate, or mark for review

# ── App ──────────────────────────────────────────────────
PORT=8000
LOG_LEVEL=INFO
LOG_DIR=./logs
